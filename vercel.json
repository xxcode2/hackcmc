{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {"runtime": "python3.9"}
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py",
      "headers": {
        "Cache-Control": "no-cache"
      }
    }
  ],
  "env": {
    "FLASK_ENV": "production"
  }
}